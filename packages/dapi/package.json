{
  "name": "@baadal-sdk/dapi",
  "version": "0.0.0",
  "description": "Dead-simple API wrappers",
  "author": "abraj",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "tsc": "tsc -b",
    "build": "tsup --dts",
    "build:server": "tsup",
    "pack": "pnpm pack --pack-destination ../../artifacts",
    "prepublishOnly": "pnpm build",
    "demo": "tsx demo/fs-demo.ts",
    "clean": "rm -rf node_modules dist tsconfig.tsbuildinfo"
  },
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baadal/baadal-sdk.git",
    "directory": "packages/dapi"
  },
  "homepage": "https://github.com/baadal/baadal-sdk/tree/main/packages/dapi#readme",
  "keywords": [
    "aws",
    "s3",
    "dynamodb",
    "fs",
    "github"
  ],
  "dependencies": {
    "@aws-sdk/client-dynamodb": "catalog:",
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/lib-dynamodb": "catalog:",
    "js-base64": "catalog:",
    "mime-types": "catalog:",
    "short-uuid": "catalog:"
  },
  "devDependencies": {
    "@types/mime-types": "catalog:"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "splitting": false,
    "sourcemap": true,
    "clean": true
  }
}
